// Run all cv2 test files and return an aggregate report.
// Keep every test file self-contained and returning util.testRunner.report().

var files = [
    "/test/cv2/core.aardio",
    "/test/cv2/mat_core.aardio",
    "/test/cv2/core_arith.aardio",
    "/test/cv2/imgproc_morph.aardio",
    "/test/cv2/imgproc_contours.aardio",
    "/test/cv2/imgproc_edges_transform.aardio",
    "/test/cv2/imgproc_perspective_hough.aardio",
    "/test/cv2/videoio.aardio",
    "/test/cv2/imgproc_features.aardio",
    "/test/cv2/features_orb_matcher.aardio",
    "/test/cv2/imgproc_preprocess.aardio",
    "/test/cv2/imgproc_analysis.aardio",
    "/test/cv2/imgproc_geometry_extra.aardio",
    "/test/cv2/core_polar_math.aardio",
    "/test/cv2/core_matrix_ops.aardio",
    "/test/cv2/core_frequency.aardio",
    "/test/cv2/core_stats_transform.aardio",
    "/test/cv2/core_sampling_analysis.aardio",
    "/test/cv2/core_linalg.aardio",
    "/test/cv2/core_pca_shape.aardio",
    "/test/cv2/core_shape_advanced.aardio",
    "/test/cv2/core_extra50.aardio",
    "/test/cv2/imgproc_segmentation_extra.aardio",
    "/test/cv2/core_extra_more.aardio",
    "/test/cv2/core_io_channels_extra.aardio",
    "/test/cv2/api_batches_abc.aardio",
    "/test/cv2/video_photo_extra.aardio",
    "/test/cv2/dnn_basic.aardio",
    "/test/cv2/dnn_caffe_relu.aardio",
    "/test/cv2/dnn_onnx_relu.aardio",
    "/test/cv2/dnn_postprocess.aardio",
    "/test/cv2/dnn_detection_postprocess.aardio",
    "/test/cv2/dnn_ssd_detection.aardio",
    "/test/cv2/dnn_segmentation_postprocess.aardio",
    "/test/cv2/dnn_visualization.aardio",
    "/test/cv2/highgui.aardio"
];

var reports = [];
var total = 0;
var failed = 0;
var passed = 0;

for(i=1;#files;1){
    var report = loadcodex(files[i]);
    table.push(reports,{
        file = files[i];
        report = report;
    });
    total += report.total : 0;
    failed += report.failed : 0;
    passed += report.passed : 0;
}

return {
    success = failed == 0;
    total = total;
    passed = passed;
    failed = failed;
    reports = reports;
};
