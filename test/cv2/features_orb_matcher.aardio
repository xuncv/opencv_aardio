import util.testRunner;
import cv2;

var $ = util.testRunner("cv2 ORB and BFMatcher features");

var img,err = cv2.imread('/assets/images/Lena.jpg',cv2.IMREAD_GRAYSCALE);
$.test(img !== null,"load grayscale Lena",err);

var orb = cv2.ORB_create(200);
var keypoints,descriptors = orb.detectAndCompute(img);
$.test(keypoints.count >= 50,"ORB detects enough keypoints",keypoints.count);
$.expect(descriptors.shape,[keypoints.count,32,1],"ORB descriptor shape");
$.expect(descriptors.typeValue,cv2.CV_8UC1,"ORB descriptor type");

var firstKeyPoint = keypoints.get(0);
$.test(firstKeyPoint.pt[1] >= 0 && firstKeyPoint.pt[1] < img.width,"KeyPoint x in image",firstKeyPoint);
$.test(firstKeyPoint.pt[2] >= 0 && firstKeyPoint.pt[2] < img.height,"KeyPoint y in image",firstKeyPoint);
$.test(firstKeyPoint.size > 0,"KeyPoint size",firstKeyPoint);
$.expect(#keypoints.toArray(),keypoints.count,"KeyPoints.toArray count");

var drawn = cv2.drawKeypoints(img,keypoints);
$.expect(drawn.shape,[img.height,img.width,3],"drawKeypoints output shape");

var matcher = cv2.BFMatcher_create(cv2.NORM_HAMMING,true);
var matches = matcher.match(descriptors,descriptors);
$.expect(matches.count,keypoints.count,"BFMatcher_create self-match count");
var firstMatch = matches.get(0);
$.expect(firstMatch.distance,0,"BFMatcher self-match zero distance");
$.expect(firstMatch.queryIdx,firstMatch.trainIdx,"BFMatcher self-match index");
$.expect(#matches.toArray(),matches.count,"Matches.toArray count");

var drawnMatches = cv2.drawMatches(img,keypoints,img,keypoints,matches);
$.expect(drawnMatches.height,img.height,"drawMatches output height");
$.expect(drawnMatches.width,img.width * 2,"drawMatches output width");
$.expect(drawnMatches.channels(),3,"drawMatches output channels");

var brisk = cv2.BRISK_create();
var briskKeypoints,briskDescriptors = brisk.detectAndCompute(img);
$.test(briskKeypoints.count >= 0,"BRISK_create detector is callable");
$.test(briskDescriptors !== null,"BRISK_create returns descriptor Mat");
brisk.release();

var akaze = cv2.AKAZE_create();
var akazeKeypoints,akazeDescriptors = akaze.detectAndCompute(img);
$.test(akazeKeypoints.count >= 0,"AKAZE_create detector is callable");
$.test(akazeDescriptors !== null,"AKAZE_create returns descriptor Mat");
akaze.release();

var kaze = cv2.KAZE_create();
var kazeKeypoints,kazeDescriptors = kaze.detectAndCompute(img);
$.test(kazeKeypoints.count >= 0,"KAZE_create detector is callable");
$.test(kazeDescriptors !== null,"KAZE_create returns descriptor Mat");
kaze.release();

for i,maker in [cv2.FastFeatureDetector_create,cv2.AgastFeatureDetector_create,cv2.GFTTDetector_create,cv2.MSER_create,cv2.SimpleBlobDetector_create]{
    var detector = maker();
    var detectorKeypoints = detector.detect(img);
    $.test(type.rget(detectorKeypoints)=="cv2.KeyPoints","feature detector factory returns KeyPoints #" + i);
    detector.release();
}

var convertedPts = cv2.KeyPoint_convert(keypoints);
$.expect(#convertedPts,keypoints.count,"KeyPoint_convert KeyPoints count");
$.test(type(convertedPts[1])=="table" && #convertedPts[1] == 2,"KeyPoint_convert point shape");
$.test(cv2.KeyPoint_overlap({pt=[0,0];size=10},{pt=[0,0];size=10}) > 0.99,"KeyPoint_overlap identical circles");

var descriptorMatcher = cv2.DescriptorMatcher_create("BruteForce-Hamming");
$.test(type.rget(descriptorMatcher)=="cv2.BFMatcher","DescriptorMatcher_create BruteForce-Hamming");
descriptorMatcher.release();

orb.release();
matcher.release();

return $.report();
