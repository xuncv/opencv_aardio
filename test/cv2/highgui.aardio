import util.testRunner;
import cv2;

var $ = util.testRunner("cv2 highgui wrappers");

var ok,err = cv2.init();
$.test(ok,"cv2 init",err);

$.test(type(cv2.imshow) == "function","imshow exported");
$.test(type(cv2.waitKey) == "function","waitKey exported");
$.test(type(cv2.namedWindow) == "function","namedWindow exported");
$.test(type(cv2.destroyAllWindows) == "function","destroyAllWindows exported");
$.test(cv2.WINDOW_AUTOSIZE == 1,"WINDOW_AUTOSIZE constant");
$.test(cv2.WINDOW_NORMAL == 0,"WINDOW_NORMAL constant");

// Do not call imshow or a zero-delay wait in automated tests to avoid blocking CI or the IDE.
// waitKey(1) is non-blocking and validates HighGUI binding availability.
var key = cv2.waitKey(1);
$.test(type(key) == "number","waitKey(1) returns numeric key code");
$.test(cv2.destroyAllWindows(),"destroyAllWindows safe call");

return $.report();
