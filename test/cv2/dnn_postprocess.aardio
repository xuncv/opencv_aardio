import cv2;
import util.testRunner;

var $ = util.testRunner("cv2 DNN postprocess helpers");

var scores = [1,3,2];
var soft = cv2.dnnSoftmax(scores);
var sumSoft = 0;
for i,v in soft sumSoft += v;
$.test(#soft == 3,"softmax 返回数组长度");
$.test(math.abs(sumSoft - 1) < 0.000001,"softmax 概率和为 1");
$.test(soft[2] > soft[3] && soft[3] > soft[1],"softmax 保持分数排序");

var maxIdx,maxVal = cv2.dnnArgMax(scores);
$.expect(maxIdx,2,"argmax 索引");
$.expect(maxVal,3,"argmax 值");

var top = cv2.dnnTopK(scores,2);
$.expect(#top,2,"topK 返回数量");
$.expect(top[1].index,2,"topK 第 1 名索引");
$.expect(top[1].score,3,"topK 第 1 名分数");
$.expect(top[2].index,3,"topK 第 2 名索引");
$.expect(top[2].score,2,"topK 第 2 名分数");

var labels = ["cat","dog","bird"];
var decoded = cv2.dnnDecodeClassification(scores,labels,2,true);
$.expect(#decoded,2,"decodeClassification 返回 top2");
$.expect(decoded[1].label,"dog","decodeClassification label");
$.test(decoded[1].probability > decoded[2].probability,"decodeClassification softmax 概率排序");

var m = cv2.Mat(1,3,cv2.CV_32FC1);
m.set(0,0,1).set(0,1,3).set(0,2,2);
var topFromMat = cv2.dnnTopK(m,1);
$.expect(topFromMat[1].index,2,"topK 支持 Mat 输入");
$.expect(topFromMat[1].score,3,"topK Mat 分数");

return $.report();
