        public double Val0;
        public double Val1;
        public double Val2;
        public double Val3;
        public ScalarResult(Scalar s){ Val0 = s.Val0; Val1 = s.Val1; Val2 = s.Val2; Val3 = s.Val3; }
    }

    public sealed class ScalarPairResult {
        public ScalarResult First;
        public ScalarResult Second;
        public ScalarPairResult(Scalar first, Scalar second){ First = new ScalarResult(first); Second = new ScalarResult(second); }
    }

    public sealed class ByteArrayResult {
        public byte[] Data;
        public ByteArrayResult(byte[] data){ Data = data ?? new byte[0]; }
        public int Length { get { return Data.Length; } }
        public int GetByte(int index){ return Data[index]; }
        public byte[] ToArray(){ return Data; }
    }

    public sealed class MomentsResult {
        public double M00, M10, M01, M20, M11, M02, M30, M21, M12, M03;
        public double Mu20, Mu11, Mu02, Mu30, Mu21, Mu12, Mu03;
        public double Nu20, Nu11, Nu02, Nu30, Nu21, Nu12, Nu03;
        public MomentsResult(Moments m){
            M00 = m.M00; M10 = m.M10; M01 = m.M01; M20 = m.M20; M11 = m.M11; M02 = m.M02;
            M30 = m.M30; M21 = m.M21; M12 = m.M12; M03 = m.M03;
            Mu20 = m.Mu20; Mu11 = m.Mu11; Mu02 = m.Mu02; Mu30 = m.Mu30; Mu21 = m.Mu21; Mu12 = m.Mu12; Mu03 = m.Mu03;
            Nu20 = m.Nu20; Nu11 = m.Nu11; Nu02 = m.Nu02; Nu30 = m.Nu30; Nu21 = m.Nu21; Nu12 = m.Nu12; Nu03 = m.Nu03;
        }
    }

    public sealed class RectResult {
        public int X;
        public int Y;
        public int Width;
        public int Height;
        public RectResult(Rect r){ X = r.X; Y = r.Y; Width = r.Width; Height = r.Height; }
    }

    public sealed class Point2fArrayResult {
        public Point2f[] Points;
