    public sealed class NetORB : IDisposable {
        public ORB Value;
        public NetORB(int nfeatures){ Value = ORB.Create(nfeatures); }
        public DetectAndComputeResult DetectAndCompute(NetMat image){
            KeyPoint[] keypoints;
            var descriptors = new Mat();
            Value.DetectAndCompute(image.Value, null, out keypoints, descriptors);
            return new DetectAndComputeResult(keypoints, descriptors);
        }
        public void Dispose(){ if(Value != null){ Value.Dispose(); Value = null; } }
    }

    public sealed class NetBFMatcher : IDisposable {
        public BFMatcher Value;
        public NetBFMatcher(int normType, bool crossCheck){ Value = new BFMatcher((NormTypes)normType, crossCheck); }
        public NetMatches Match(NetMat queryDescriptors, NetMat trainDescriptors){ return new NetMatches(Value.Match(queryDescriptors.Value, trainDescriptors.Value)); }
        public void Dispose(){ if(Value != null){ Value.Dispose(); Value = null; } }
    }

    public sealed class NetDnn : IDisposable {
        public Net Value;
        public NetDnn(){ Value = new Net(); }
        public NetDnn(Net net){ Value = net ?? new Net(); }
        public bool Empty(){ return Value.Empty(); }
        public void SetInput(NetMat blob, string name){
            if(String.IsNullOrEmpty(name)) Value.SetInput(blob.Value);
            else Value.SetInput(blob.Value, name);
        }
        public NetMat Forward(string outputName){
            if(String.IsNullOrEmpty(outputName)) return new NetMat(Value.Forward());
            return new NetMat(Value.Forward(outputName));
        }
        public MatArrayResult ForwardLayers(string[] outBlobNames){
            var names = outBlobNames;
            if(names == null || names.Length == 0) names = Value.GetUnconnectedOutLayersNames();
            var outs = new List<Mat>();
            Value.Forward(outs, names);
            return new MatArrayResult(outs.ToArray());
        }
        public string[] GetLayerNames(){ return Value.GetLayerNames(); }
        public string[] GetUnconnectedOutLayersNames(){ return Value.GetUnconnectedOutLayersNames(); }
        public void SetPreferableBackend(int backend){ Value.SetPreferableBackend((Backend)backend); }
        public void SetPreferableTarget(int target){ Value.SetPreferableTarget((Target)target); }
        public PerfProfileResult GetPerfProfile(){ double[] timings; var ticks = Value.GetPerfProfile(out timings); return new PerfProfileResult(ticks, timings); }
        public string Dump(){ return Value.Dump(); }
        public void Dispose(){ if(Value != null){ Value.Dispose(); Value = null; } }
    }

    public sealed class CaptureReadResult {
        public bool Ok;
        public NetMat Frame;
        public CaptureReadResult(bool ok, Mat frame){ Ok = ok; Frame = new NetMat(frame ?? new Mat()); }
    }

    public sealed class NetVideoCapture : IDisposable {
        public VideoCapture Value;
        public NetVideoCapture(int index){ Value = new VideoCapture(index); }
        public NetVideoCapture(string fileName){ Value = new VideoCapture(fileName); }
        public bool IsOpened(){ return Value != null && Value.IsOpened(); }
        public CaptureReadResult Read(){ var frame = new Mat(); var ok = Value.Read(frame); return new CaptureReadResult(ok, frame); }
        public bool Grab(){ return Value.Grab(); }
        public CaptureReadResult Retrieve(){ var frame = new Mat(); var ok = Value.Retrieve(frame); return new CaptureReadResult(ok, frame); }
        public double Get(int propId){ return Value.Get((VideoCaptureProperties)propId); }
        public bool Set(int propId, double value){ return Value.Set((VideoCaptureProperties)propId, value); }
        public void Release(){ if(Value != null) Value.Release(); }
        public void Dispose(){ if(Value != null){ Value.Dispose(); Value = null; } }
    }

    public sealed class NetVideoWriter : IDisposable {
        public VideoWriter Value;
        public NetVideoWriter(string fileName, int fourcc, double fps, int width, int height, bool isColor){ Value = new VideoWriter(fileName, fourcc, fps, new Size(width, height), isColor); }
        public bool IsOpened(){ return Value != null && Value.IsOpened(); }
        public void Write(NetMat image){ Value.Write(image.Value); }
        public void Release(){ if(Value != null) Value.Release(); }
        public void Dispose(){ if(Value != null){ Value.Dispose(); Value = null; } }
    }

