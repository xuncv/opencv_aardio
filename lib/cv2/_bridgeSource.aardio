        public static NetMat GrabCut(NetMat image, int x, int y, int width, int height, int iterCount, int mode){ var mask = new Mat(image.Value.Size(), MatType.CV_8UC1, Scalar.All(0)); var bgd = new Mat(); var fgd = new Mat(); Cv2.GrabCut(image.Value, mask, new Rect(x, y, width, height), bgd, fgd, iterCount, (GrabCutModes)mode); return new NetMat(mask); }
