        public static PyrLKResult CalcOpticalFlowPyrLK(NetMat prevImg, NetMat nextImg, double[] prevPointsFlat, int winWidth, int winHeight, int maxLevel, int maxCount, double epsilon, int flags, double minEigThreshold){
            int n = prevPointsFlat == null ? 0 : prevPointsFlat.Length / 2;
            var prevPts = new Point2f[n];
            for(int i=0;i<n;i++) prevPts[i] = new Point2f((float)prevPointsFlat[i*2], (float)prevPointsFlat[i*2+1]);
            Point2f[] nextPts = new Point2f[n];
            for(int i=0;i<n;i++) nextPts[i] = prevPts[i];
            byte[] status;
            float[] err;
            Cv2.CalcOpticalFlowPyrLK(prevImg.Value, nextImg.Value, prevPts, ref nextPts, out status, out err, new Size(winWidth,winHeight), maxLevel, new TermCriteria(CriteriaTypes.Count | CriteriaTypes.Eps, maxCount, epsilon), (OpticalFlowFlags)flags, minEigThreshold);
            return new PyrLKResult(nextPts, status, err);
        }
