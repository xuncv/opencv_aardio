        public static ContoursResult FindContours(NetMat src, int mode, int method, int offsetX, int offsetY){
            Point[][] contours;
            HierarchyIndex[] hierarchy;
            using(var work = src.Value.Clone()){
                Cv2.FindContours(work, out contours, out hierarchy, (RetrievalModes)mode, (ContourApproximationModes)method, new Point(offsetX, offsetY));
            }
            return new ContoursResult(contours, hierarchy);
        }
