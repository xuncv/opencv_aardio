        public double CenterX;
        public double CenterY;
        public double Width;
        public double Height;
        public double Angle;
        public RotatedRectResult(RotatedRect r){ CenterX = r.Center.X; CenterY = r.Center.Y; Width = r.Size.Width; Height = r.Size.Height; Angle = r.Angle; }
    }

    public sealed class MeanShiftResult {
        public int Iterations;
