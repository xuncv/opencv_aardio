        public static NetMat RandShuffle(NetMat dst, double iterFactor){
            if(dst.Value.Channels() != 1) throw new NotSupportedException("RandShuffle currently supports single-channel Mat only.");
            var tmp = new Mat();
            dst.Value.ConvertTo(tmp, MatType.CV_64F);
            int n = tmp.Rows * tmp.Cols;
            var values = new double[n];
            for(int i=0;i<n;i++) values[i] = tmp.Get<double>(i / tmp.Cols, i % tmp.Cols);
            var rng = new Random();
            int swaps = Math.Max(n, (int)Math.Round(n * Math.Max(0.0, iterFactor)));
            for(int i=0;i<swaps;i++){
                int a = rng.Next(n);
                int b = rng.Next(n);
                var v = values[a]; values[a] = values[b]; values[b] = v;
            }
            for(int i=0;i<n;i++) tmp.Set(i / tmp.Cols, i % tmp.Cols, values[i]);
            tmp.ConvertTo(dst.Value, dst.Value.Type());
            tmp.Dispose();
            return dst;
        }
