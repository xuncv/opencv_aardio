namespace cv2._bridgeSource;

// C# source for Aardio.OpenCvSharpBridge.
// Split from cv2/_.aardio to keep the public API aggregator small and easier to maintain.
source = /***
using System;
using System.Collections.Generic;
using System.Runtime.InteropServices;
using OpenCvSharp;
using OpenCvSharp.Dnn;

namespace Aardio.OpenCvSharpBridge {
    public sealed class NetMat : IDisposable {
        public Mat Value;
        public NetMat(){ Value = new Mat(); }
        public NetMat(Mat mat){ Value = mat ?? new Mat(); }
        public int Rows { get { return Value.Rows; } }
        public int Cols { get { return Value.Cols; } }
        public int Width { get { return Value.Cols; } }
        public int Height { get { return Value.Rows; } }
        public int TypeValue { get { return Value.Type().Value; } }
        public string TypeName { get { return Value.Type().ToString(); } }
        public int Depth { get { return Value.Depth(); } }
        public long ElemSize { get { return (long)Value.ElemSize(); } }
        public long ElemSize1 { get { return (long)Value.ElemSize1(); } }
        public bool IsContinuous { get { return Value.IsContinuous(); } }
        public bool IsSubmatrix { get { return Value.IsSubmatrix(); } }
        public int Channels(){ return Value.Channels(); }
        public int Dims { get { return Value.Dims; } }
        public int SizeAt(int dimension){ return Value.Size(dimension); }
        public long Total { get { return (long)Value.Total(); } }
        public long TotalValues { get { return (long)Value.Total() * (long)Value.Channels(); } }
        public bool Empty(){ return Value.Empty(); }
        public NetMat Clone(){ return new NetMat(Value.Clone()); }
        public NetMat Row(int y){ return new NetMat(Value.Row(y)); }
        public NetMat Col(int x){ return new NetMat(Value.Col(x)); }
        public NetMat RowRange(int start, int end){ return new NetMat(Value.RowRange(start, end)); }
        public NetMat ColRange(int start, int end){ return new NetMat(Value.ColRange(start, end)); }
        public NetMat Roi(int x, int y, int width, int height){ return new NetMat(new Mat(Value, new Rect(x, y, width, height))); }
        public NetMat ConvertTo(int rtype, double alpha, double beta){ var dst = new Mat(); Value.ConvertTo(dst, new MatType(rtype), alpha, beta); return new NetMat(dst); }
        public NetMat Reshape(int cn, int rows){ return new NetMat(Value.Reshape(cn, rows)); }
        public NetMat SetTo(double v0, double v1, double v2, double v3){ Value.SetTo(new Scalar(v0, v1, v2, v3)); return this; }
        public double GetDouble(int row, int col, int channel){
            if(Value.Channels() > 1){
                using(var single = new Mat()){
                    Cv2.ExtractChannel(Value, single, channel);
                    return GetSingleDouble(single, row, col);
                }
            }
            return GetSingleDouble(Value, row, col);
        }
        public void SetDouble(int row, int col, double value){
            if(Value.Channels() != 1) throw new NotSupportedException("SetDouble only supports single-channel Mat; use Split/Merge for multi-channel Mat.");
            switch(Value.Depth()){
                case 0: Value.Set(row, col, (byte)value); break;
                case 1: Value.Set(row, col, (sbyte)value); break;
                case 2: Value.Set(row, col, (ushort)value); break;
                case 3: Value.Set(row, col, (short)value); break;
                case 4: Value.Set(row, col, (int)value); break;
                case 5: Value.Set(row, col, (float)value); break;
                case 6: Value.Set(row, col, (double)value); break;
                default: throw new NotSupportedException("Unsupported Mat depth: " + Value.Depth());
            }
        }
        public byte[] ToBytes(){
            var m = Value.IsContinuous() ? Value : Value.Clone();
            try{
                long len64 = (long)m.Total() * (long)m.ElemSize();
                if(len64 > int.MaxValue) throw new InvalidOperationException("Mat is too large to copy into a byte array.");
                var bytes = new byte[(int)len64];
                Marshal.Copy(m.Data, bytes, 0, bytes.Length);
                return bytes;
            }
            finally{
                if(!Object.ReferenceEquals(m, Value)) m.Dispose();
            }
        }
        public float[] ToFloatArray(){
            Mat converted = null;
            var m = Value;
            if(m.Depth() != 5/*CV_32F*/){
                converted = new Mat();
                m.ConvertTo(converted, MatType.CV_32F);
                m = converted;
            }
            if(!m.IsContinuous()){
                var cloned = m.Clone();
                if(converted != null) converted.Dispose();
                converted = cloned;
                m = converted;
            }
            try{
                long len64 = (long)m.Total() * (long)m.Channels();
                if(len64 > int.MaxValue) throw new InvalidOperationException("Mat is too large to copy into a float array.");
                var values = new float[(int)len64];
                Marshal.Copy(m.Data, values, 0, values.Length);
                return values;
            }
            finally{
                if(converted != null) converted.Dispose();
            }
        }
        public double[] ToDoubleArray(){
            Mat converted = null;
            var m = Value;
            if(m.Depth() != 6/*CV_64F*/){
                converted = new Mat();
                m.ConvertTo(converted, MatType.CV_64F);
                m = converted;
            }
            if(!m.IsContinuous()){
                var cloned = m.Clone();
                if(converted != null) converted.Dispose();
                converted = cloned;
                m = converted;
            }
            try{
                long len64 = (long)m.Total() * (long)m.Channels();
                if(len64 > int.MaxValue) throw new InvalidOperationException("Mat is too large to copy into a double array.");
                var values = new double[(int)len64];
                Marshal.Copy(m.Data, values, 0, values.Length);
                return values;
            }
            finally{
                if(converted != null) converted.Dispose();
            }
        }
        private static double GetSingleDouble(Mat m, int row, int col){
            switch(m.Depth()){
                case 0: return m.Get<byte>(row, col);
                case 1: return m.Get<sbyte>(row, col);
                case 2: return m.Get<ushort>(row, col);
                case 3: return m.Get<short>(row, col);
                case 4: return m.Get<int>(row, col);
                case 5: return m.Get<float>(row, col);
                case 6: return m.Get<double>(row, col);
                default: throw new NotSupportedException("Unsupported Mat depth: " + m.Depth());
            }
        }
        public string Dump(){ return Value.Dump(); }
        public override string ToString(){ return Value.ToString(); }
        public void Dispose(){ if(Value != null){ Value.Dispose(); Value = null; } }
    }

    public sealed class ThresholdResult {
        public double RetVal;
        public NetMat Mat;
        public ThresholdResult(double retVal, Mat mat){ RetVal = retVal; Mat = new NetMat(mat); }
    }

    public sealed class TwoMatResult {
        public NetMat Mat1;
        public NetMat Mat2;
        public TwoMatResult(Mat mat1, Mat mat2){ Mat1 = new NetMat(mat1); Mat2 = new NetMat(mat2); }
    }

    public sealed class ThreeMatResult {
        public NetMat Mat1;
        public NetMat Mat2;
        public NetMat Mat3;
        public ThreeMatResult(Mat mat1, Mat mat2, Mat mat3){ Mat1 = new NetMat(mat1); Mat2 = new NetMat(mat2); Mat3 = new NetMat(mat3); }
    }

    public sealed class MatWithRetValResult {
        public double RetVal;
        public NetMat Mat;
        public MatWithRetValResult(double retVal, Mat mat){ RetVal = retVal; Mat = new NetMat(mat); }
    }

    public sealed class BoolMatResult {
        public bool Ok;
        public NetMat Mat;
        public BoolMatResult(bool ok, Mat mat){ Ok = ok; Mat = new NetMat(mat); }
    }

    public sealed class BoolTwoMatResult {
        public bool Ok;
        public NetMat Mat1;
        public NetMat Mat2;
