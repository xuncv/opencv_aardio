        public static TwoMatResult BatchDistance(NetMat src1, NetMat src2, int dtype, int normType, int k){
            var a = new Mat(); var b = new Mat();
            src1.Value.ConvertTo(a, MatType.CV_64F);
            src2.Value.ConvertTo(b, MatType.CV_64F);
            var dist = new Mat(a.Rows, b.Rows, new MatType(dtype), Scalar.All(0));
            var nidx = k > 0 ? new Mat(a.Rows, k, MatType.CV_32S, Scalar.All(0)) : new Mat();
            for(int i=0;i<a.Rows;i++){
                var vals = new double[b.Rows];
                for(int j=0;j<b.Rows;j++){
                    double d = 0;
                    if(normType == 2/*NORM_L1*/){
                        for(int c=0;c<a.Cols;c++) d += Math.Abs(a.Get<double>(i,c) - b.Get<double>(j,c));
                    }
                    else if(normType == 1/*NORM_INF*/){
                        for(int c=0;c<a.Cols;c++) d = Math.Max(d, Math.Abs(a.Get<double>(i,c) - b.Get<double>(j,c)));
                    }
                    else{
                        for(int c=0;c<a.Cols;c++){ var diff = a.Get<double>(i,c) - b.Get<double>(j,c); d += diff * diff; }
                        if(normType != 5/*NORM_L2SQR*/) d = Math.Sqrt(d);
                    }
                    vals[j] = d;
                    if(dtype == (int)MatType.CV_32F) dist.Set<float>(i,j,(float)d);
                    else if(dtype == (int)MatType.CV_64F) dist.Set<double>(i,j,d);
                    else dist.Set<int>(i,j,(int)Math.Round(d));
                }
                if(k > 0){
                    for(int kk=0;kk<k;kk++){
                        int best = 0; double bestVal = Double.MaxValue;
                        for(int j=0;j<vals.Length;j++) if(vals[j] < bestVal){ bestVal = vals[j]; best = j; }
                        nidx.Set<int>(i,kk,best); vals[best] = Double.MaxValue;
                    }
                }
            }
            a.Dispose(); b.Dispose();
            return new TwoMatResult(dist, nidx);
        }
