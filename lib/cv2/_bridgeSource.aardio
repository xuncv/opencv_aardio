        public static PolarLineResult[] HoughLines(NetMat image, double rho, double theta, int threshold, double srn, double stn){
            var lines = Cv2.HoughLines(image.Value, rho, theta, threshold, srn, stn);
            var ret = new PolarLineResult[lines == null ? 0 : lines.Length];
            for(int i=0;i<ret.Length;i++) ret[i] = new PolarLineResult(lines[i]);
            return ret;
        }
