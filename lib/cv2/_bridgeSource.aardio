    public sealed class MinMaxResult {
        public double MinVal;
        public double MaxVal;
        public int MinX;
        public int MinY;
        public int MaxX;
        public int MaxY;
        public MinMaxResult(double minVal, double maxVal, Point minLoc, Point maxLoc){
            MinVal = minVal; MaxVal = maxVal;
            MinX = minLoc.X; MinY = minLoc.Y; MaxX = maxLoc.X; MaxY = maxLoc.Y;
        }
    }

    public sealed class MinMaxIdxResult {
        public double MinVal;
        public double MaxVal;
        public int MinRow;
        public int MinCol;
        public int MaxRow;
        public int MaxCol;
        public MinMaxIdxResult(double minVal, double maxVal, int[] minIdx, int[] maxIdx){
            MinVal = minVal; MaxVal = maxVal;
            MinRow = minIdx != null && minIdx.Length > 0 ? minIdx[0] : 0;
            MinCol = minIdx != null && minIdx.Length > 1 ? minIdx[1] : 0;
            MaxRow = maxIdx != null && maxIdx.Length > 0 ? maxIdx[0] : 0;
            MaxCol = maxIdx != null && maxIdx.Length > 1 ? maxIdx[1] : 0;
        }
    }

    public sealed class TextSizeResult {
        public int Width;
        public int Height;
        public int BaseLine;
        public TextSizeResult(Size size, int baseLine){ Width = size.Width; Height = size.Height; BaseLine = baseLine; }
    }

    public sealed class RQDecompResult {
        public double X;
        public double Y;
        public double Z;
        public NetMat MtxR;
        public NetMat MtxQ;
        public RQDecompResult(Vec3d angles, Mat mtxR, Mat mtxQ){ X = angles.Item0; Y = angles.Item1; Z = angles.Item2; MtxR = new NetMat(mtxR); MtxQ = new NetMat(mtxQ); }
    }

    public sealed class CalibrationMatrixValuesResult {
        public double FovX;
        public double FovY;
        public double FocalLength;
        public double PrincipalPointX;
        public double PrincipalPointY;
        public double AspectRatio;
        public CalibrationMatrixValuesResult(double fovx, double fovy, double focalLength, Point2d principalPoint, double aspectRatio){
            FovX = fovx; FovY = fovy; FocalLength = focalLength;
            PrincipalPointX = principalPoint.X; PrincipalPointY = principalPoint.Y; AspectRatio = aspectRatio;
        }
    }

    public sealed class ClipLineResult {
        public bool Ok;
        public int X1;
        public int Y1;
        public int X2;
        public int Y2;
        public ClipLineResult(bool ok, Point pt1, Point pt2){ Ok = ok; X1 = pt1.X; Y1 = pt1.Y; X2 = pt2.X; Y2 = pt2.Y; }
    }

