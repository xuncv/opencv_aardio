        public static int VideoWriterFourCC(string code){
            if(String.IsNullOrEmpty(code) || code.Length != 4) throw new ArgumentException("fourcc must be a 4-character string, e.g. MJPG", "code");
            return OpenCvSharp.VideoWriter.FourCC(code[0], code[1], code[2], code[3]);
        }
        public static NetVideoWriter VideoWriter(string fileName, int fourcc, double fps, int width, int height, bool isColor){ return new NetVideoWriter(fileName, fourcc, fps, width, height, isColor); }
