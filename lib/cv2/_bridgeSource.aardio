        public static IntArrayResult NMSBoxes(double[] boxes, double[] scores, double scoreThreshold, double nmsThreshold, double eta, int topK){
            if(boxes == null) boxes = new double[0];
            if(scores == null) scores = new double[0];
            int n = boxes.Length / 4;
            var rects = new Rect[n];
            for(int i=0;i<n;i++) rects[i] = new Rect((int)boxes[i*4], (int)boxes[i*4+1], (int)boxes[i*4+2], (int)boxes[i*4+3]);
            var fscores = new float[scores.Length];
            for(int i=0;i<scores.Length;i++) fscores[i] = (float)scores[i];
            int[] indices;
            CvDnn.NMSBoxes(rects, fscores, (float)scoreThreshold, (float)nmsThreshold, out indices, (float)eta, topK);
            return new IntArrayResult(indices);
        }
