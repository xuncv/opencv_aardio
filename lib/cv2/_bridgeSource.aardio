            Rect rect;
            var area = Cv2.FloodFill(image.Value, new Point(x, y), new Scalar(nv0, nv1, nv2, nv3), out rect, new Scalar(lo0, lo1, lo2, lo3), new Scalar(up0, up1, up2, up3), (FloodFillFlags)flags);
