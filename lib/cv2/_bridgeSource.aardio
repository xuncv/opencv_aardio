        public static ConvexIntersectionResult IntersectConvexConvex(NetContour contour1, NetContour contour2, bool handleNested){
            Point2f[] p1 = Array.ConvertAll(contour1.Points, pt => new Point2f(pt.X, pt.Y));
            Point2f[] p2 = Array.ConvertAll(contour2.Points, pt => new Point2f(pt.X, pt.Y));
            Point2f[] outPts;
            double area = Cv2.IntersectConvexConvex(p1, p2, out outPts, handleNested);
            return new ConvexIntersectionResult(area, outPts);
        }
        public static RotatedRectIntersectionResult RotatedRectangleIntersection(double cx1, double cy1, double w1, double h1, double angle1, double cx2, double cy2, double w2, double h2, double angle2){
            var r1 = new RotatedRect(new Point2f((float)cx1, (float)cy1), new Size2f((float)w1, (float)h1), (float)angle1);
            var r2 = new RotatedRect(new Point2f((float)cx2, (float)cy2), new Size2f((float)w2, (float)h2), (float)angle2);
            Point2f[] pts;
            var typ = Cv2.RotatedRectangleIntersection(r1, r2, out pts);
            return new RotatedRectIntersectionResult(typ, pts);
        }
