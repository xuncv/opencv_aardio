        public double Vx;
        public double Vy;
        public double X0;
        public double Y0;
        public Line2DResult(Line2D line){ Vx = line.Vx; Vy = line.Vy; X0 = line.X1; Y0 = line.Y1; }
    }

    public sealed class NetCLAHE : IDisposable {
        private CLAHE clahe;
        public NetCLAHE(double clipLimit, int tileGridWidth, int tileGridHeight){ clahe = Cv2.CreateCLAHE(clipLimit, new Size(tileGridWidth, tileGridHeight)); }
        public NetMat Apply(NetMat src){ var dst = new Mat(); clahe.Apply(src.Value, dst); return new NetMat(dst); }
        public double ClipLimit { get { return clahe.ClipLimit; } set { clahe.ClipLimit = value; } }
        public void CollectGarbage(){ clahe.CollectGarbage(); }
        public void Dispose(){ if(clahe != null){ clahe.Dispose(); clahe = null; } }
    }

    public sealed class FloodFillResult {
        public int Area;
        public RectResult Rect;
        public FloodFillResult(int area, Rect rect){ Area = area; Rect = new RectResult(rect); }
    }

    public sealed class HierarchyResult {
        public int Next;
        public int Previous;
        public int Child;
        public int Parent;
        public HierarchyResult(HierarchyIndex h){ Next = h.Next; Previous = h.Previous; Child = h.Child; Parent = h.Parent; }
    }

    public sealed class NetContour {
        public Point[] Points;
        public NetContour(Point[] points){ Points = points ?? new Point[0]; }
        public int Count { get { return Points.Length; } }
        public int GetX(int index){ return Points[index].X; }
        public int GetY(int index){ return Points[index].Y; }
        public double Area(bool oriented){ return Cv2.ContourArea(Points, oriented); }
        public double ArcLength(bool closed){ return Cv2.ArcLength(Points, closed); }
        public RectResult BoundingRect(){ return new RectResult(Cv2.BoundingRect(Points)); }
        public NetContour ApproxPolyDP(double epsilon, bool closed){ return new NetContour(Cv2.ApproxPolyDP(Points, epsilon, closed)); }
    }

    public sealed class ContoursResult {
        public NetContour[] Contours;
        public HierarchyResult[] Hierarchy;
        public ContoursResult(Point[][] contours, HierarchyIndex[] hierarchy){
            Contours = new NetContour[contours == null ? 0 : contours.Length];
            for(int i=0;i<Contours.Length;i++) Contours[i] = new NetContour(contours[i]);
            Hierarchy = new HierarchyResult[hierarchy == null ? 0 : hierarchy.Length];
            for(int i=0;i<Hierarchy.Length;i++) Hierarchy[i] = new HierarchyResult(hierarchy[i]);
        }
        public int Count { get { return Contours.Length; } }
        public NetContour GetContour(int index){ return Contours[index]; }
        public HierarchyResult GetHierarchy(int index){ return Hierarchy[index]; }
    }

