    public sealed class PyrLKResult {
        public Point2f[] Points;
        public byte[] Status;
        public float[] Err;
        public PyrLKResult(Point2f[] points, byte[] status, float[] err){ Points = points ?? new Point2f[0]; Status = status ?? new byte[0]; Err = err ?? new float[0]; }
        public int Count { get { return Points.Length; } }
        public double GetX(int index){ return Points[index].X; }
        public double GetY(int index){ return Points[index].Y; }
        public int GetStatus(int index){ return index < Status.Length ? Status[index] : 0; }
        public double GetErr(int index){ return index < Err.Length ? Err[index] : 0; }
    }

    public sealed class MatArrayResult {
        public NetMat[] Mats;
        public MatArrayResult(Mat[] mats){
            if(mats == null) mats = new Mat[0];
            Mats = new NetMat[mats.Length];
            for(int i=0;i<mats.Length;i++) Mats[i] = new NetMat(mats[i]);
        }
        public int Count { get { return Mats.Length; } }
        public NetMat GetMat(int index){ return Mats[index]; }
    }

    public sealed class PyramidResult {
        public int Levels;
        public NetMat[] Mats;
        public PyramidResult(int levels, Mat[] mats){
            Levels = levels;
            if(mats == null) mats = new Mat[0];
            Mats = new NetMat[mats.Length];
            for(int i=0;i<mats.Length;i++) Mats[i] = new NetMat(mats[i]);
        }
        public int Count { get { return Mats.Length; } }
        public NetMat GetMat(int index){ return Mats[index]; }
    }

    public sealed class PerfProfileResult {
        public long Ticks;
        public double[] Timings;
        public PerfProfileResult(long ticks, double[] timings){ Ticks = ticks; Timings = timings ?? new double[0]; }
        public int Count { get { return Timings.Length; } }
        public double GetTiming(int index){ return Timings[index]; }
    }

