        public double GetX(int index){ return Points[index].X; }
        public double GetY(int index){ return Points[index].Y; }
    }

    public sealed class IntArrayResult {
        public int[] Values;
        public IntArrayResult(int[] values){ Values = values ?? new int[0]; }
        public int Count { get { return Values.Length; } }
        public int Get(int index){ return Values[index]; }
    }

