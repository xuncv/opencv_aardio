        public static ByteArrayResult ImEncode(string ext, NetMat img){ byte[] data; Cv2.ImEncode(ext, img.Value, out data); return new ByteArrayResult(data); }
        public static NetMat ImDecode(ByteArrayResult data, int flags){ return new NetMat(Cv2.ImDecode(data.ToArray(), (ImreadModes)flags)); }
        public static NetMat ImDecodeBytes(int[] data, int flags){ var bytes = new byte[data == null ? 0 : data.Length]; for(int i=0;i<bytes.Length;i++) bytes[i] = (byte)(data[i] & 0xFF); return new NetMat(Cv2.ImDecode(bytes, (ImreadModes)flags)); }
        public static NetMat BlobFromImage(NetMat image, double scaleFactor, int width, int height, double mean0, double mean1, double mean2, double mean3, bool swapRB, bool crop){ return new NetMat(CvDnn.BlobFromImage(image.Value, scaleFactor, new Size(width, height), new Scalar(mean0, mean1, mean2, mean3), swapRB, crop)); }
        public static NetMat BlobFromImages(NetMat[] images, double scaleFactor, int width, int height, double mean0, double mean1, double mean2, double mean3, bool swapRB, bool crop){
            if(images == null) images = new NetMat[0];
            var mats = new Mat[images.Length];
            for(int i=0;i<images.Length;i++) mats[i] = images[i].Value;
            return new NetMat(CvDnn.BlobFromImages(mats, scaleFactor, new Size(width, height), new Scalar(mean0, mean1, mean2, mean3), swapRB, crop));
        }
        public static NetDnn ReadNet(string model, string config, string framework){ return new NetDnn(CvDnn.ReadNet(model, config, framework)); }
        public static NetDnn ReadNetFromOnnx(string path){ return new NetDnn(CvDnn.ReadNetFromOnnx(path)); }
        public static NetDnn ReadNetFromCaffe(string prototxt, string caffeModel){ return new NetDnn(CvDnn.ReadNetFromCaffe(prototxt, caffeModel)); }
        public static NetDnn ReadNetFromDarknet(string cfgFile, string darknetModel){ return new NetDnn(CvDnn.ReadNetFromDarknet(cfgFile, darknetModel)); }
