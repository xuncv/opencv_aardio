}

abs = function(src){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.Abs(_asNetMat(src)));
}
Abs = abs;

copyTo = function(src,mask){
    init();
    if(mask) return Mat(..Aardio.OpenCvSharpBridge.Cv.CopyTo(_asNetMat(src),_asNetMat(mask)));
    return Mat(..Aardio.OpenCvSharpBridge.Cv.CopyToNoMask(_asNetMat(src)));
}
CopyTo = copyTo;

bitwise_not = function(src){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.BitwiseNot(_asNetMat(src)));
}

bitwise_and = function(src1,src2){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.BitwiseAnd(_asNetMat(src1),_asNetMat(src2)));
}

bitwise_or = function(src1,src2){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.BitwiseOr(_asNetMat(src1),_asNetMat(src2)));
}

bitwise_xor = function(src1,src2){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.BitwiseXor(_asNetMat(src1),_asNetMat(src2)));
}

bitwiseNot = bitwise_not; BitwiseNot = bitwise_not;
bitwiseAnd = bitwise_and; BitwiseAnd = bitwise_and;
bitwiseOr = bitwise_or; BitwiseOr = bitwise_or;
bitwiseXor = bitwise_xor; BitwiseXor = bitwise_xor;

