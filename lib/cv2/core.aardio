min = function(src1,src2){ init(); return Mat(type(src2)==type.number ? ..Aardio.OpenCvSharpBridge.Cv.MinScalar(_asNetMat(src1),src2) : ..Aardio.OpenCvSharpBridge.Cv.Min(_asNetMat(src1),_asNetMat(src2))); }

