batchDistance = function(src1,src2,dtype=5/*CV_32F*/,normType=4/*NORM_L2*/,k=0){
    init();
    var rows1,rows2,cols = src1.rows,src2.rows,src1.cols;
    var dist = Mat(rows1,rows2,dtype);
    var nidx = k > 0 ? Mat(rows1,k,4/*CV_32SC1*/) : Mat();
    for(i=0;rows1-1;1){
        var vals = [];
        for(j=0;rows2-1;1){
            var d = 0;
            if(normType == 2/*NORM_L1*/){
                for(c=0;cols-1;1) d += ..math.abs(src1.get(i,c) - src2.get(j,c));
            }
            elseif(normType == 1/*NORM_INF*/){
                for(c=0;cols-1;1) d = ..math.max(d, ..math.abs(src1.get(i,c) - src2.get(j,c)));
            }
            else {
                for(c=0;cols-1;1){
                    var diff = src1.get(i,c) - src2.get(j,c);
                    d += diff * diff;
                }
                if(normType != 5/*NORM_L2SQR*/) d = ..math.sqrt(d);
            }
            dist.set(i,j,d);
            vals[j+1] = d;
        }
        if(k > 0){
            for(kk=0;k-1;1){
                var best,bestVal = 0, 1e308;
                for(j=1;#vals;1){
                    if(vals[j] < bestVal){ bestVal = vals[j]; best = j-1; }
                }
                nidx.set(i,kk,best);
                vals[best+1] = 1e308;
            }
        }
    }
    return dist,nidx;
}

