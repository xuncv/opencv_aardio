kmeans = function(data,k,maxIter=10,epsilon=1.0,attempts=1,flags=2/*KMEANS_PP_CENTERS*/){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.KMeans(_asNetMat(data),k,maxIter,epsilon,attempts,flags);
    return r.Compactness,Mat(r.Labels),Mat(r.Centers);
}
