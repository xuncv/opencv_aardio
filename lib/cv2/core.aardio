    var r = ..Aardio.OpenCvSharpBridge.Cv.MinMaxIdx(_asNetMat(src));
    return {minVal=r.MinVal; maxVal=r.MaxVal; minIdx=[r.MinRow,r.MinCol]; maxIdx=[r.MaxRow,r.MaxCol]};
}

