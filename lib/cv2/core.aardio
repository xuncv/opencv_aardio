namespace cv2.core{}
namespace cv2;

// Core matrix operations, arithmetic, linalg, transforms, DFT, PCA, integral, kmeans
// Split from cv2/_.aardio. Public API remains under namespace cv2.

add = function(src1,src2,dtype=-1){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.Add(_asNetMat(src1),_asNetMat(src2),dtype));
}

subtract = function(src1,src2,dtype=-1){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.Subtract(_asNetMat(src1),_asNetMat(src2),dtype));
}

multiply = function(src1,src2,scale=1.0,dtype=-1){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.Multiply(_asNetMat(src1),_asNetMat(src2),scale,dtype));
}

divide = function(src1,src2,scale=1.0,dtype=-1){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.Divide(_asNetMat(src1),_asNetMat(src2),scale,dtype));
}

absdiff = function(src1,src2){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.Absdiff(_asNetMat(src1),_asNetMat(src2)));
}

addWeighted = function(src1,alpha,src2,beta,gamma=0.0,dtype=-1){
