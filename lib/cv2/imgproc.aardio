rotatedRectangleIntersection = function(rect1,rect2){
    init();
    var c1x,c1y,w1,h1,a1 = _rotatedRectArgs(rect1);
    var c2x,c2y,w2,h2,a2 = _rotatedRectArgs(rect2);
    return _rotatedRectIntersectionTable(..Aardio.OpenCvSharpBridge.Cv.RotatedRectangleIntersection(c1x,c1y,w1,h1,a1,c2x,c2y,w2,h2,a2));
}

applyCLAHE = function(src,clipLimit=40.0,tileGridSize){
    init();
    var width,height = 8,8;
    if(tileGridSize) width,height = _size2wh(tileGridSize);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.CLAHEApply(_asNetMat(src),clipLimit,width,height));
}

drawContours = function(img,contours,contourIdx=-1,color=255,thickness=1,lineType=8/*LINE_8*/){
    init();
    var v0,v1,v2,v3 = _scalar4(color);
    if(contourIdx >= 0){
        ..Aardio.OpenCvSharpBridge.Cv.DrawContour(_asNetMat(img),contours[contourIdx+1].net,v0,v1,v2,v3,thickness,lineType);
    }
    else {
        for(i,contour in contours){
            ..Aardio.OpenCvSharpBridge.Cv.DrawContour(_asNetMat(img),contour.net,v0,v1,v2,v3,thickness,lineType);
        }
    }
    return img;
}

rectangle = function(img,pt1,pt2,color=255,thickness=1,lineType=8/*LINE_8*/){
    init();
    var x1,y1 = _size2wh(pt1);
    var x2,y2 = _size2wh(pt2);
    var v0,v1,v2,v3 = _scalar4(color);
    ..Aardio.OpenCvSharpBridge.Cv.Rectangle(_asNetMat(img),x1,y1,x2-x1,y2-y1,v0,v1,v2,v3,thickness,lineType);
    return img;
}

