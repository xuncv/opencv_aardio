compareHist = function(h1,h2,method=0/*HISTCMP_CORREL*/){ init(); return ..Aardio.OpenCvSharpBridge.Cv.CompareHist(_asNetMat(h1),_asNetMat(h2),method); }
phaseCorrelate = function(src1,src2,window){
    init();
    var r = window ? ..Aardio.OpenCvSharpBridge.Cv.PhaseCorrelate(_asNetMat(src1),_asNetMat(src2),_asNetMat(window)) : ..Aardio.OpenCvSharpBridge.Cv.PhaseCorrelateNoWindow(_asNetMat(src1),_asNetMat(src2));
    return [r.X,r.Y],r.Response;
}
