goodFeaturesToTrack = function(image,maxCorners=100,qualityLevel=0.01,minDistance=1.0,blockSize=3,useHarrisDetector=false,k=0.04){
    init();
    var corners = ..Aardio.OpenCvSharpBridge.Cv.GoodFeaturesToTrack(_asNetMat(image),maxCorners,qualityLevel,minDistance,blockSize,useHarrisDetector,k);
    var ret = [];
    for(i=0;corners.Length-1;1){
        var corner = corners.GetValue(i);
        ..table.push(ret,[corner.X,corner.Y]);
    }
    return ret;
}

cornerSubPix = function(image,corners,winSize,zeroZone,maxIter=40,epsilon=0.001){
    init();
    if(!winSize) winSize = [5,5];
    if(!zeroZone) zeroZone = [-1,-1];
    var winW,winH = _size2wh(winSize);
    var zeroW,zeroH = _size2wh(zeroZone);
    return _point2fArray(..Aardio.OpenCvSharpBridge.Cv.CornerSubPix(_asNetMat(image),_pointsToFlatArray(corners,2),winW,winH,zeroW,zeroH,maxIter,epsilon));
}

connectedComponentsWithStats = function(image,connectivity=8,ltype=4/*CV_32S*/){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.ConnectedComponentsWithStats(_asNetMat(image),connectivity,ltype);
    return r.Count, Mat(r.Labels), Mat(r.Stats), Mat(r.Centroids);
}

connectedComponents = function(image,connectivity=8,ltype=4/*CV_32S*/){
    var count,labels = connectedComponentsWithStats(image,connectivity,ltype);
    return count,labels;
}

connectedComponentsWithAlgorithm = function(image,connectivity=8,ltype=4/*CV_32S*/,ccltype=-1/*CCL_DEFAULT*/){
    init();
