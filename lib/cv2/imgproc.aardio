namespace cv2.imgproc{}
namespace cv2;

// Image processing: morphology, channels/statistics, contours, drawing, geometry, Hough, components, histogram
// Split from cv2/_.aardio. Public API remains under namespace cv2.

getStructuringElement = function(shape,ksize,anchor){
    init();
    var width,height = _size2wh(ksize);
    var anchorX,anchorY = -1,-1;
    if(anchor) anchorX,anchorY = _size2wh(anchor);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.GetStructuringElement(shape,width,height,anchorX,anchorY));
}

erode = function(src,kernel,iterations=1,borderType=4/*BORDER_DEFAULT*/,borderValue){
    init();
    var v0,v1,v2,v3 = _scalar4(borderValue);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.Erode(_asNetMat(src),_asNetMat(kernel),iterations,borderType,v0,v1,v2,v3));
}

dilate = function(src,kernel,iterations=1,borderType=4/*BORDER_DEFAULT*/,borderValue){
    init();
    var v0,v1,v2,v3 = _scalar4(borderValue);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.Dilate(_asNetMat(src),_asNetMat(kernel),iterations,borderType,v0,v1,v2,v3));
}

morphologyEx = function(src,op,kernel,iterations=1,borderType=4/*BORDER_DEFAULT*/,borderValue){
    init();
    var v0,v1,v2,v3 = _scalar4(borderValue);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.MorphologyEx(_asNetMat(src),op,_asNetMat(kernel),iterations,borderType,v0,v1,v2,v3));
}

morphologyDefaultBorderValue = function(){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.MorphologyDefaultBorderValue();
    return [r.Val0,r.Val1,r.Val2,r.Val3];
}

copyMakeBorder = function(src,top,bottom,left,right,borderType=0/*BORDER_CONSTANT*/,color){
    init();
    var v0,v1,v2,v3 = _scalar4(color);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.CopyMakeBorder(_asNetMat(src),top,bottom,left,right,borderType,v0,v1,v2,v3));
}

extractChannel = function(src,coi){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.ExtractChannel(_asNetMat(src),coi));
}

split = function(src){
    init();
    var ret = [];
    for(i=0;src.channels()-1;1){
        ..table.push(ret,extractChannel(src,i));
    }
    return ret;
}

merge = function(mats){
    init();
    var n = #mats;
    if(n == 1) return Mat(..Aardio.OpenCvSharpBridge.Cv.Merge1(_asNetMat(mats[1])));
    if(n == 2) return Mat(..Aardio.OpenCvSharpBridge.Cv.Merge2(_asNetMat(mats[1]),_asNetMat(mats[2])));
    if(n == 3) return Mat(..Aardio.OpenCvSharpBridge.Cv.Merge3(_asNetMat(mats[1]),_asNetMat(mats[2]),_asNetMat(mats[3])));
    if(n == 4) return Mat(..Aardio.OpenCvSharpBridge.Cv.Merge4(_asNetMat(mats[1]),_asNetMat(mats[2]),_asNetMat(mats[3]),_asNetMat(mats[4])));
    error("cv2.merge 当前仅支持 1 到 4 个通道",2);
}

hconcat = function(src1,src2){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.HConcat2(_asNetMat(src1),_asNetMat(src2)));
}

vconcat = function(src1,src2){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.VConcat2(_asNetMat(src1),_asNetMat(src2)));
}

minMaxLoc = function(src){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.MinMaxLoc(_asNetMat(src));
    return r.MinVal,r.MaxVal,[r.MinX,r.MinY],[r.MaxX,r.MaxY];
}

mean = function(src){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.Mean(_asNetMat(src));
    return [r.Val0,r.Val1,r.Val2,r.Val3];
}

meanStdDev = function(src){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.MeanStdDev(_asNetMat(src));
    return [r.First.Val0,r.First.Val1,r.First.Val2,r.First.Val3],[r.Second.Val0,r.Second.Val1,r.Second.Val2,r.Second.Val3];
}

norm = function(src1,src2,normType=4/*NORM_L2*/){
    init();
    if(src2 === null) return ..Aardio.OpenCvSharpBridge.Cv.Norm(_asNetMat(src1),normType);
    if(type(src2)==type.number) return ..Aardio.OpenCvSharpBridge.Cv.Norm(_asNetMat(src1),src2);
    return ..Aardio.OpenCvSharpBridge.Cv.Norm2(_asNetMat(src1),_asNetMat(src2),normType);
}

sumElems = function(src){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.SumElems(_asNetMat(src));
    return [r.Val0,r.Val1,r.Val2,r.Val3];
}
sum = sumElems; Sum = sumElems;

trace = function(src){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.Trace(_asNetMat(src));
    return [r.Val0,r.Val1,r.Val2,r.Val3];
}

moments = function(src,binaryImage=false){
    init();
    return _momentsTable(..Aardio.OpenCvSharpBridge.Cv.Moments(_asNetMat(src),binaryImage));
}

contourMoments = function(contour,binaryImage=false){
    init();
    return _momentsTable(..Aardio.OpenCvSharpBridge.Cv.ContourMoments(contour.net,binaryImage));
}

HuMoments = function(src,binaryImage=false){
    var m;
    if(type.rget(src)=="cv2.Contour") m = contourMoments(src,binaryImage);
    else m = moments(src,binaryImage);
    return _huMomentsFromTable(m);
}

countNonZero = function(src){
    init(); return ..Aardio.OpenCvSharpBridge.Cv.CountNonZero(_asNetMat(src));
}

inRange = function(src,lowerb,upperb){
    init();
    var l0,l1,l2,l3 = _scalar4(lowerb);
    var u0,u1,u2,u3 = _scalar4(upperb);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.InRange(_asNetMat(src),l0,l1,l2,l3,u0,u1,u2,u3));
}

findContours = function(src,mode=0/*RETR_EXTERNAL*/,method=2/*CHAIN_APPROX_SIMPLE*/,offset){
    init();
    var offsetX,offsetY = _size2wh(offset);
    if(offsetX === null) offsetX = 0;
    if(offsetY === null) offsetY = 0;
    var r = ..Aardio.OpenCvSharpBridge.Cv.FindContours(_asNetMat(src),mode,method,offsetX,offsetY);
    var contours = [];
    var hierarchy = [];
    for(i=0;r.Count-1;1){
        ..table.push(contours,Contour(r.GetContour(i)));
        var h = r.GetHierarchy(i);
        ..table.push(hierarchy,[h.Next,h.Previous,h.Child,h.Parent]);
    }
    return contours,hierarchy;
}

contourArea = function(contour,oriented=false){
    init(); return ..Aardio.OpenCvSharpBridge.Cv.ContourArea(contour.net,oriented);
}

arcLength = function(curve,closed=true){
