    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.ConnectedComponentsWithStatsWithAlgorithm(_asNetMat(image),connectivity,ltype,ccltype);
    return r.Count, Mat(r.Labels), Mat(r.Stats), Mat(r.Centroids);
}

distanceTransform = function(src,distanceType=2/*DIST_L2*/,maskSize=3/*DIST_MASK_3*/){
