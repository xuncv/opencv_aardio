watershed = function(image,markers){
    init(); return Mat(..Aardio.OpenCvSharpBridge.Cv.Watershed(_asNetMat(image),_asNetMat(markers)));
}

HoughLines = function(image,rho,theta,threshold,srn=0.0,stn=0.0){
    init();
    var lines = ..Aardio.OpenCvSharpBridge.Cv.HoughLines(_asNetMat(image),rho,theta,threshold,srn,stn);
    var ret = [];
    for(i=0;lines.Length-1;1){
        var line = lines.GetValue(i);
        ..table.push(ret,[line.Rho,line.Theta]);
    }
    return ret;
}

HoughLinesP = function(image,rho,theta,threshold,minLineLength=0.0,maxLineGap=0.0){
    init();
    var lines = ..Aardio.OpenCvSharpBridge.Cv.HoughLinesP(_asNetMat(image),rho,theta,threshold,minLineLength,maxLineGap);
    var ret = [];
    for(i=0;lines.Length-1;1){
        var line = lines.GetValue(i);
        ..table.push(ret,[line.X1,line.Y1,line.X2,line.Y2]);
    }
    return ret;
}

HoughCircles = function(image,method=3/*HOUGH_GRADIENT*/,dp=1.0,minDist=1.0,param1=100.0,param2=10.0,minRadius=0,maxRadius=0){
    init();
    var circles = ..Aardio.OpenCvSharpBridge.Cv.HoughCircles(_asNetMat(image),method,dp,minDist,param1,param2,minRadius,maxRadius);
    var ret = [];
    for(i=0;circles.Length-1;1){
        var c = circles.GetValue(i);
        ..table.push(ret,[c.X,c.Y,c.Radius]);
    }
    return ret;
}

