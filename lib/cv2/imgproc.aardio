floodFill = function(image,seedPoint,newVal,loDiff,upDiff,flags=4){
    init();
    var x,y = _point2(seedPoint);
    var nv0,nv1,nv2,nv3 = _scalar4(newVal);
    var lo0,lo1,lo2,lo3 = _scalar4(loDiff);
    var up0,up1,up2,up3 = _scalar4(upDiff);
    var r = ..Aardio.OpenCvSharpBridge.Cv.FloodFill(_asNetMat(image),x,y,nv0,nv1,nv2,nv3,lo0,lo1,lo2,lo3,up0,up1,up2,up3,flags);
    return r.Area,[r.Rect.X,r.Rect.Y,r.Rect.Width,r.Rect.Height];
}

grabCut = function(image,rect,iterCount=1,mode=0/*GC_INIT_WITH_RECT*/){
    init();
    var x,y,w,h = _rect4(rect);
    return Mat(..Aardio.OpenCvSharpBridge.Cv.GrabCut(_asNetMat(image),x,y,w,h,iterCount,mode));
