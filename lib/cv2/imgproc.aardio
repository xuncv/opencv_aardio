}

distanceTransformWithLabels = function(src,distanceType=2/*DIST_L2*/,maskSize=3/*DIST_MASK_3*/,labelType=0/*DIST_LABEL_CCOMP*/){
    init();
    var r = ..Aardio.OpenCvSharpBridge.Cv.DistanceTransformWithLabels(_asNetMat(src),distanceType,maskSize,labelType);
    return Mat(r.Mat1),Mat(r.Mat2);
}

